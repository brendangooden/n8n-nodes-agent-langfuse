{
  "name": "n8n-nodes-agent-langfuse",
  "version": "0.2.1",
  "description": "n8n AI Agent node with native Langfuse integration: tracing + prompt management",
  "keywords": [
    "n8n-community-node-package",
    "langfuse",
    "langchain",
    "ai-agent",
    "observability",
    "tracing"
  ],
  "license": "MIT",
  "author": {
    "name": "diward",
    "email": "edu.diward@gmail.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Diward/n8n-nodes-agent-langfuse.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "mkdir -p dist/nodes/AgentLangfuse/icons && cp nodes/AgentLangfuse/icons/*.svg dist/nodes/AgentLangfuse/icons/",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LangfuseApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AgentLangfuse/AgentLangfuse.node.js"
    ]
  },
  "dependencies": {
    "@langchain/core": ">=0.3.58 <0.4.0",
    "@langchain/openai": "^0.4.0",
    "langchain": "^0.3.0",
    "langfuse": "^3.0.0",
    "langfuse-langchain": "^3.0.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "n8n-workflow": "^2.13.1",
    "typescript": "^6.0.3"
  }
}
